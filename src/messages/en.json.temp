  "aboutTech": {
    "category": "In-house Lab",
    "title": "The only tooth in the world,\ndesigned one by one at our in-house Blanche Lab",
    "features": {
      "0": {
        "title": "1:1 Custom Design",
        "description": "We analyze your face shape, lip line, skin tone, and gum line to design the most natural tooth. It's a custom prosthesis just for you, not a ready-made product from a factory."
      },
      "1": {
        "title": "Replicating Natural Teeth",
        "description": "A natural tooth is not just one color. Through dozens of ceramic layerings, we replicate the transparency for light transmission and subtle color tones."
      },
      "2": {
        "title": "Real-time Communication",
        "description": "Our resident lab team participates in treatments. Since the medical staff and lab technicians communicate and modify instantly, more precise and faster results are possible compared to external labs."
      },
      "3": {
        "title": "Premium Materials and Equipment",
        "description": "We use verified top-grade zirconia & ceramic materials, and ultra-precise 3D digital scanners. We create prosthetics that are aesthetically beautiful and functionally long-lasting."
      }
    }
  },
  "aboutEquipment": {
    "category": "Digital Equipment",
    "title": "With university hospital-level equipment,\nwe treat more precisely and safely",
    "list": {
      "0": {
        "nameKo": "Prime Scan",
        "nameEn": "Dentsply Sirona, Germany",
        "tag": "Precise Diagnosis",
        "subText": "Scans with light, without impressions",
        "description": "Scans the mouth digitally without uncomfortable rubber impression materials. Precise to over 1M points/sec, enabling flawless prosthetic design."
      },
      "1": {
        "nameKo": "Ultra-precise 3D CT",
        "nameEn": "Dentium Bright CT",
        "tag": "Precise Diagnosis",
        "subText": "Checks bones and nerves in 3D",
        "description": "Identifies gum bone condition and nerve position in 0.1mm units. Low-dose tech minimizes radiation exposure while establishing safe implant/orthodontic plans."
      },
      "2": {
        "nameKo": "WaterLase",
        "nameEn": "Water Drop Laser",
        "tag": "Precise Diagnosis",
        "subText": "Treats smoothly, without vibration",
        "description": "Uses water and laser instead of drill noise and vibration to treat gums. Less pain and bleeding for faster recovery."
      },
      "3": {
        "nameKo": "Ivoclar Press Furnace",
        "nameEn": "Ivoclar Programat",
        "tag": "Precise Production · In-house Lab",
        "subText": "Replicates the transparency of natural teeth exactly",
        "description": "Produces ceramic prosthetics using equipment from Ivoclar, a global dental material company. Bakes at a constant temperature/pressure for a color and transparency hard to distinguish from natural teeth."
      },
      "4": {
        "nameKo": "Zirconia Milling Machine",
        "nameEn": "Zirconia Milling Machine",
        "tag": "Precise Production · In-house Lab",
        "subText": "Carves precisely down to the micro unit",
        "description": "Precisely processes zirconia based on digital design data. Produces prosthetics that fit the teeth and gum line perfectly."
      },
      "5": {
        "nameKo": "Digital Painless Anesthesia Machine",
        "nameEn": "I-JECT",
        "tag": "Comfort and Safety",
        "subText": "Minimizes the pain of anesthesia injections",
        "description": "Injects anesthetic fluid at a constant speed and pressure, reducing stinging pain."
      },
      "6": {
        "nameKo": "Ultra-high Pressure Sterilization System",
        "nameEn": "Autoclave",
        "tag": "Comfort and Safety",
        "subText": "Thorough sterilization system with no cross-infection worries",
        "description": "All instruments undergo ultra-high pressure sterilization. We strictly adhere to the 1-instrument-per-person rule, prioritizing patient safety."
      }
    }
  },
