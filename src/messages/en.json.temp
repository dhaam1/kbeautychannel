    "afterAlt": "After Treatment"
  },
  "casesPhilosophyDetails": {
    "category": "Philosophy",
    "title": "We think like this",
    "description1": "Blanche Dental Clinic\nwill shoulder your worries for you.",
    "description2": "Not just a good dental clinic,\nbut a clinic that brings happiness.",
    "description3": "We will repay the courage you mustered to visit amidst worries\nwith a bright smile and health."
