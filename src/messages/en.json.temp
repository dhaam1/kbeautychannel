  "aboutHero": {
    "label": "About Blanche Dental Clinic",
    "consultationBtn": "Book Consultation",
    "title": "The Dental Atelier Designing Your Smile, \nBlanche",
    "description": "White as snow, Blanche.\nWe restore the clearest and most transparent natural beauty.\nWe complete a natural and luxurious smile with detailed design."
  },
  "aboutStrength": {
    "category": "Treatment Philosophy",
    "title": "We think about your smile\neven 20 years later",
    "description": "Blanche Dental Clinic creates masterpieces\nthat last a long time.",
    "cases": {
      "0": {
        "title": "Not just a simple laminate",
        "quote": "Is it necessary to damage teeth worth over $100k just to look pretty?\nBlanche started from that question.\nMaximum beauty with minimal intervention.\nThat is the value Blanche pursues."
      },
      "1": {
        "title": "We communicate kindly\nand listen carefully",
        "quote": "Dental treatment is never an easy process.\n\nBlanche makes it a rule to repeat all explanations at least four times.\nWe constantly check for any discomfort\nand will continue to improve."
      },
      "2": {
        "title": "We constantly invest\nfor the best environment",
        "quote": "While skill is important in dental treatment,\nthe environment and equipment are equally important.\nWe constantly invest to treat without fear and pain."
      },
      "3": {
        "title": "If we can't do it,\nno one can",
        "quote": "Trained at Seoul National University and Columbia & UCLA Dental Hospitals.\n\nWe are confident that Blanche's treatment, equipment, and medical staff are world-class."
      }
    }
  },
  "aboutDirector": {
    "category": "Introducing the Chief Director",
    "title": "Beyond teeth,\nwe design lives",
    "description": "We create teeth that will be with you for a lifetime,\nand restore a healthy smile",
    "name": "Chief Director Kim Tae-Hyung",
    "credentials": "Major Career\n• Graduated from Seoul National University Dental College\n• Master's from SNU Graduate School of Dentistry\n• Trained at US Columbia & UCLA Dental Hospitals\n• Dental Advisor for SBS 'Doctor O's Clinic', YouTube 'Doctor Friends'\n• Clinical Advisor for Straumann & Osstem Implants\n• Surgery Center Director for Flapless Sleep Implants\n• Holds record for most Straumann BLX procedures\n• Selected among Top 100 Doctors in Korea (Implant Division)\n• Thesis (Study on the effect of professional teeth whitening)"
  },
